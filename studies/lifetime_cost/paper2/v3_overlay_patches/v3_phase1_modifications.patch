+                    continue
+                for gid in group_ids:
+                    comp_key = make_block_hash_with_group_id(comp_hashes[i], gid)
+                    recl_key = make_block_hash_with_group_id(recl_hashes[i], gid)
+                    block = block_pool.cached_block_hash_to_block.get_one_block(
+                        comp_key
