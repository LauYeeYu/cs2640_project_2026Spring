+    def _dual_key_blocks_for_recall(
+        self,
+        pending: list,  # list[tuple[list[int], list[int]]]
+    ) -> None:
+        """Phase 8: dual-key cached blocks under recall-prompt chain hashes.
+
+        For each (compacted_tokens, recall_tokens) pair: walk both block-by-
+        block; where compacted_hash[i] != recall_hash[i] AND a block exists
+        in cache under compacted_hash[i] (and not yet under recall_hash[i]),
+        insert it under recall_hash[i] too.
+
+        Pure metadata operation — no KV bytes move. The block's K vectors
+        retain their original RoPE bake-in; on the recall chat the request's
+        allocate_slots finds them via cache hit, no re-prefill. Suffix RoPE
+        ends up off by `m` (obs's token count) — slight correctness loss.
+        """
+        from vllm.v1.core.kv_cache_utils import make_block_hash_with_group_id
+        block_pool = self.kv_cache_manager.block_pool
+        try:
+            kv_groups = self.kv_cache_config.kv_cache_groups
+        except Exception:
+            kv_groups = []
+        # For models with a single attention type (Qwen3 etc.) there's
+        # one group. Use group_id=0; multi-group models would need
+        # per-group dual-keying which we don't tackle here.
+        group_ids = list(range(max(1, len(kv_groups)))) if kv_groups else [0]
