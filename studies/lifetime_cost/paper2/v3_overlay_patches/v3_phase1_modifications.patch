+    def _snapshot_gpu_mem(self, label: str) -> None:
+        """Phase 9: append a GPU memory snapshot to a jsonl trace.
+
+        Writes to PAPER2_GPU_MEM_TRACE_PATH if set; no-op otherwise. Each
+        line records:
+          - label (which Phase 9 event this is)
+          - alloc_bytes (torch.cuda.memory_allocated)
+          - reserved_bytes (torch.cuda.memory_reserved)
+          - num_free_blocks (block_pool.get_num_free_blocks)
+          - timestamp
+        Plot script later joins these against the engine's [v9-rotate]
+        and [v3-restore-splice] markers to make memory-over-time figures.
+        """
+        import os as _os
+        path = _os.environ.get("PAPER2_GPU_MEM_TRACE_PATH")
+        if not path:
+            return
+        try:
+            import torch as _torch
+            import time as _time
+            import json as _json
+            alloc = _torch.cuda.memory_allocated() if _torch.cuda.is_available() else 0
+            reserved = _torch.cuda.memory_reserved() if _torch.cuda.is_available() else 0
+            try:
+                from vllm.v1.core.block_masking.memento_store import (
+                    ENGINE_STATS,
+                    get_num_free_blocks_or_neg1 as _gnfb,
+                )
+                stats_snap = dict(ENGINE_STATS)
+                n_free = _gnfb()
+            except Exception:
+                stats_snap = {}
+                n_free = -1
+            rec = {
+                "t": _time.time(),
+                "label": label,
+                "pid": _os.getpid(),
+                "alloc_bytes": alloc,
+                "reserved_bytes": reserved,
+                "num_free_blocks": n_free,
+                "engine_stats": stats_snap,
+            }
+            with open(path, "a") as f:
+                f.write(_json.dumps(rec) + "\n")
+        except Exception:
+            pass
+
+    def _find_rotary_embedding(self):
+        """Walk the loaded model to find a RotaryEmbedding instance.
+
+        Qwen3 (and most decoder-only models we target) share a single RoPE
+        config across all attention layers, so any layer's `rotary_emb`
+        works. Caches on `self._cached_rotary_emb` after first lookup.
+        Returns None if no RoPE is found (e.g., a model without RoPE).
+        """
+        cached = getattr(self, "_cached_rotary_emb", None)
+        if cached is not None:
+            return cached
+        try:
+            from vllm.model_executor.layers.rotary_embedding import (
+                RotaryEmbedding,
+            )
+        except Exception:
+            return None
+        # Walk submodules and pick the first RotaryEmbedding-like module.
+        for module in self.model.modules():
+            if isinstance(module, RotaryEmbedding):
+                self._cached_rotary_emb = module
+                return module
+            if module.__class__.__name__.endswith("RotaryEmbedding"):
+                self._cached_rotary_emb = module
+                return module
+        return None
+
+    def _execute_kv_rotate_operations(
+        self,
+        kv_rotate_operations: dict,
+    ) -> None:
+        """Phase 9: rotate cached suffix K vectors by delta_tokens in place.
+
+        Called after a kvrestore splice has shifted the suffix's logical
+        positions. RoPE composition R(p+Δ) = R(Δ) ∘ R(p) means we can
+        correct the suffix's K phase by applying a single rotation by Δ
+        to the cached K. Pure tensor op; no model forward, no re-prefill.
+
+        For each KVRotateOp:
+          1. Gather K from `suffix_block_ids` for every layer.
+          2. Apply rotary kernel with positions = [delta_tokens] * n_tokens.
+          3. Scatter K back. V is left untouched (RoPE only rotates K).
+        """
+        if not self.kv_caches or not kv_rotate_operations:
+            return
+        import torch as _torch
+
+        rope = self._find_rotary_embedding()
+        if rope is None:
+            print("[v9-rotate] no RotaryEmbedding found on model; skipping rotation",
+                  flush=True)
+            return
+
+        first_cache = self.kv_caches[0]
+        flash_attn_layout = (first_cache.shape[0] == 2)
+        # Block size from layout
+        if flash_attn_layout:
+            # [2, num_blocks, block_size, num_kv_heads, head_size]
+            block_size = first_cache.shape[2]
+        else:
+            # [num_blocks, 2, block_size, num_kv_heads, head_size]
+            block_size = first_cache.shape[2]
+
+        total_blocks_rotated = 0
+        # max position the rotary cache supports (cos_sin_cache height).
+        # Bounds-check delta — negative deltas would crash index_select on
+        # cos_sin_cache (gather kernel out-of-bounds).
+        max_pos = int(rope.cos_sin_cache.shape[0]) if rope is not None else 0
+        for req_id, ops in kv_rotate_operations.items():
+            for op in ops:
+                block_ids = list(op.suffix_block_ids)
+                delta = int(op.delta_tokens)
+                if not block_ids or delta == 0:
+                    continue
+                if delta < 0 or delta >= max_pos:
+                    print(f"[v9-rotate-skip] req={req_id} delta={delta} "
+                          f"out of [0, {max_pos}); not rotating",
+                          flush=True)
+                    continue
+                n_blocks = len(block_ids)
+                n_tokens = n_blocks * block_size
+                idx = _torch.tensor(block_ids, dtype=_torch.long,
+                                    device=first_cache.device)
+                positions = _torch.full((n_tokens,), delta,
+                                        device=first_cache.device,
+                                        dtype=_torch.long)
+
+                for kv_cache in self.kv_caches:
+                    if flash_attn_layout:
+                        # [2, num_blocks, block_size, num_kv_heads, head_size]
+                        k_gathered = kv_cache[0].index_select(0, idx).contiguous()
+                    else:
+                        # [num_blocks, 2, block_size, num_kv_heads, head_size]
+                        k_gathered = kv_cache.index_select(0, idx)[:, 0].contiguous()
+
+                    n_heads = k_gathered.shape[2]
+                    head_size = k_gathered.shape[3]
+                    k_flat = k_gathered.reshape(n_tokens, n_heads * head_size)
+
+                    q_dummy = _torch.zeros_like(k_flat)
+                    _, k_rot_flat = rope.forward_native(positions, q_dummy, k_flat)
+
+                    k_rot = k_rot_flat.reshape(
+                        n_blocks, block_size, n_heads, head_size
+                    ).to(kv_cache.dtype)
+                    if flash_attn_layout:
+                        kv_cache[0, idx] = k_rot
+                    else:
+                        kv_cache[idx, 0] = k_rot
+
+                total_blocks_rotated += n_blocks
+                print(f"[v9-rotate] req={req_id} delta={delta} "
+                      f"suffix_blocks={n_blocks} layers={len(self.kv_caches)}",
+                      flush=True)
+
+        try:
+            from vllm.v1.core.block_masking.memento_store import bump as _bump
+            _bump("kv_rotations_executed",
+                  sum(len(ops) for ops in kv_rotate_operations.values()))
+            _bump("kv_rotations_blocks", total_blocks_rotated)
+        except Exception:
+            pass
