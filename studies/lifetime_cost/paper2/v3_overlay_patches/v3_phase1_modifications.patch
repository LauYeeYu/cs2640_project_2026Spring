+              f"{len(kv_capture_operations)} requests, {n_ops_total} ops, "
+              f"layers={num_layers}, layout={'FA' if flash_attn_layout else 'FlashInfer'}",
+              flush=True)
+
+        for req_id, ops in kv_capture_operations.items():
+            for op in ops:
