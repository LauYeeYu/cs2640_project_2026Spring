+        """Paper 2 v4 Phase 4d: recall via mask removal.
+
+        Looks up the memento in the scheduler-side store, finds its pinned
+        GPU block IDs, and removes them from the named request's
+        masked_block_ids set. The next attention forward for that request
+        will INCLUDE those blocks (paged_kv_indices filter no longer skips
+        them). KV bytes are unchanged — recall is just a set membership flip.
+
+        Returns (ok, message). Common failure modes:
+          - request_id unknown
+          - memento_id unknown or not pinned
+          - blocks weren't in the request's masked set (no-op)
+        """
+        request = self.requests.get(request_id)
+        if request is None:
+            return False, f"unknown request_id={request_id!r}"
+
+        from vllm.v1.core.block_masking.memento_store import (
+            global_memento_store as _gms,
