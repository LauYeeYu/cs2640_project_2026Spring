+    def _compute_chain_hashes(self, token_ids: list[int]) -> list:
+        """Phase 8: chain-hash a token sequence into a list of BlockHash.
+        Mirrors vllm.v1.core.kv_cache_utils.get_request_block_hasher's
+        logic for plain text (no extra_keys for multimodal/LoRA). Used
+        to dual-key existing cached blocks under the recall-prompt's
+        chain hash so vLLM's allocate_slots finds them.
+        """
+        from vllm.v1.core.kv_cache_utils import hash_block_tokens, NONE_HASH
+        from vllm.utils.hashing import get_hash_fn_by_name
+        hash_fn = get_hash_fn_by_name(
+            self.cache_config.prefix_caching_hash_algo
+        )
+        block_size = self.block_size
+        parent = NONE_HASH
+        out = []
+        n = len(token_ids)
+        for i in range(0, n - block_size + 1, block_size):
+            block_tokens = tuple(token_ids[i:i + block_size])
+            h = hash_block_tokens(hash_fn, parent, block_tokens, None)
+            out.append(h)
+            parent = h
+        return out
