+    def release_pinned_memento(self, memento_id: str) -> "tuple[bool, str]":
+        """Phase 4a inverse: drop ref_cnt on pinned GPU blocks for memento_id.
+
+        After this call, the blocks return to their pre-pin state — if no
+        other request holds them, they're added to the free queue and
+        recycled. The MementoStore entry's `gpu_pinned_block_ids` field is
+        cleared so we don't double-release.
+
+        Use cases: agent task completes; explicit policy decision to drop
+        a memento; LRU eviction of the pinned pool when GPU memory tight.
+
+        Returns (ok, message). ok=False if memento unknown or not pinned.
+        """
+        from vllm.v1.core.block_masking.memento_store import (
+            global_memento_store as _gms,
+        )
+        sched_store = _gms()
+        m = sched_store.get(memento_id)
+        if m is None:
+            return False, f"unknown memento_id={memento_id!r}"
+        if not m.gpu_pinned_block_ids:
+            return False, f"memento {memento_id!r} not GPU-pinned"
+
+        block_pool = self.kv_cache_manager.block_pool
+        released_count = 0
+        freed_to_queue = []
+        for bid in m.gpu_pinned_block_ids:
+            if 0 <= bid < len(block_pool.blocks):
+                block = block_pool.blocks[bid]
+                if block.ref_cnt > 0:
+                    block.ref_cnt -= 1
+                    released_count += 1
+                    if block.ref_cnt == 0:
+                        freed_to_queue.append(block)
+        if freed_to_queue:
+            block_pool.free_block_queue.append_n(freed_to_queue)
+
+        m.gpu_pinned_block_ids = None
+        return True, (f"released {released_count} pinned blocks "
+                      f"({len(freed_to_queue)} returned to free queue)")
